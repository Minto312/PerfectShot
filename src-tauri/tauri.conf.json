{
  "$schema": "https://raw.githubusercontent.com/nicklausw/tauri/main/.schema/config.schema.json",
  "productName": "PerfectShot",
  "version": "0.2.0",
  "identifier": "com.perfectshot.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../frontend",
    "beforeBuildCommand": "npm run build --prefix ../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "PerfectShot",
        "width": 400,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFEN0QzNkJCOTBBMTgyQkQKUldTOWdxR1F1elo5clMrTVM5K3hPV2FlZUJtaVlidlNrdnhtbGxPRWdLRjV1NytoNnpVWGQrYnQK",
      "endpoints": [
        "https://github.com/Minto312/PerfectShot/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
